    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #ffffff;
      --text: #363636;
      --text-muted: #6E6B6B;
      --cursor-default: url('https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cursor%2064x64.png') 32 32, auto;
      --cursor-alt: url('https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cursor%202%2064x64.png') 32 32, auto;
    }

    html, body {
      height: 100%;
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      cursor: var(--cursor-default);
    }

    .page-title {
      font-size: 75px;
      font-weight: 700;
      text-transform: uppercase;
      margin: 20px;
    }

    .gallery-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 5px;
      margin: 30px;
    }

   .gallery-item {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
}

    .gallery-item:hover {
      transform: scale(0.75);
      object-fit: contain;
    }

  .gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

   .overlay {
  position: absolute;
  inset: 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 12px;
  padding: 12px;
  opacity: 0;
  transition: opacity 0.2s ease;
  pointer-events: none;
}

.overlay .title {
  flex: 1;
  min-width: 0;
  text-align: left;
  font-family: 'DM Mono', monospace;
  font-size: clamp(60px, 1.6vw, 50px);
  line-height: 0.7;
  color: var(--text);
  overflow-wrap: anywhere;
}

.overlay .desc {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-family: 'DM Mono', monospace;
  font-size: clamp(25px, 1.4vw, 25px);
  line-height: 1.3;
  color: var(--text-muted);
  overflow-wrap: anywhere;
}

    #top-right-section {
