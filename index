      { name:'motherboard', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/motherboard-18022026-negative.png' },
      { name:'key', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/key-18022026-negative.png' },
      { name:'spiderman lampshades', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/lampshades-25022026-negative.png' },
      { name:'sewing pattern', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/pattern-25022026-negative.png' },
      { name:'white cabinet', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cabinet-25022026-2-negative.png' },
      { name:'bin bags', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/bin_bags-25022026-negative.png' },
      { name:'pallet', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/wood-25022026-negative.png' },
      { name:'frying pan', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/pan-25022026-negative.png' },
      { name:'bowls', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/bowl-02032026-negative.png' },
      { name:'pallet', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/wood-02032026-negative.png' },
      { name:'blue boxes', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/boxes-02032026-negative.png' },
      { name:'mirror', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/mirror-28012026-2-negative.png' },
      { name:'suitcase', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/suitcase-04022026-negative.png' },
    ];

    objects.sort((a, b) => a.name.localeCompare(b.name));

    const gallery = document.getElementById('gallery');
    const noResults = document.getElementById('no-results');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const img = entry.target;
          img.src = img.dataset.src;
          img.loading = 'lazy'; 
          observer.unobserve(img);
        }
      });
    }, {
      rootMargin: '200px'
    });

   objects.forEach(obj => {
  const item = document.createElement('div');
  item.className = 'gallery-item';
  item.dataset.name = obj.name;

  const img = document.createElement('img');
  const negativeSrc = obj.image.replace(/(\.png)$/i, '-negative$1').replace('-negative-negative', '-negative');
  const positiveSrc = obj.image; 

  img.dataset.src = negativeSrc;
  img.alt = obj.name;

  img.onload = () => {
  const preload = new Image();
  preload.src = positiveSrc;
};

  item.addEventListener('mouseenter', () => {
    if (img.src) img.src = positiveSrc;
  });
  item.addEventListener('mouseleave', () => {
    if (img.src) img.src = negativeSrc;
  });

  item.appendChild(img);
  gallery.appendChild(item);
  observer.observe(img);
});

    document.getElementById('search-input').addEventListener('input', function () {
      const query = this.value.toLowerCase().trim();
      const items = gallery.querySelectorAll('.gallery-item');
      let visibleCount = 0;

      items.forEach(item => {
        const name = item.dataset.name.toLowerCase();
        if (name.includes(query)) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      noResults.style.display = visibleCount === 0 ? 'block' : 'none';
    });

  </script>
</body>
</html>
