<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>INDEX</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@700;900&family=Source+Code+Pro&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #ffffff;
      --surface: #edeae2;
      --border: #d4cfc4;
      --text: #363636;
      --text-muted: #6E6B6B;
      --accent: #919191;
      --accent-light: #B0ABAB;
      --pill-active-bg: #363636;
      --pill-active-text: #f5f2ec;
      --pill-bg: #EDEBEB;
      --pill-border: #c4bfb4;
      --cursor-default: url('https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cursor%2064x64.png') 32 32, auto;
      --cursor-alt: url('https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cursor%202%2064x64.png') 32 32, auto;
    }

    html, body {
      height: 100%;
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      overflow-y: auto; /* FIXED: was missing semicolon */
      cursor: var(--cursor-default);
    }

    body.cursor-alt,
    body.cursor-alt * {
      cursor: var(--cursor-alt) !important;
    }

    .page-title {
      font-size: 75px;
      font-weight: 700;
      text-transform: uppercase;
      color: var(--text);
      text-align: left;
      margin: 20px 0;
      padding: 14px 20px 10px;
      background: var(--bg);
      flex-shrink: 0;
    }

    #top-right-section {
      position: absolute;
      top: 40px;
      right: -100px;
      width: 250px;
      background: rgba(255, 255, 255, 0.8);
      padding: 10px;
      border-radius: 8px;
      z-index: 200;
    }

    #top-right-section h2 {
      margin-bottom: -10px;
      font-size: 1.5em;
    }

    #top-right-section p {
      font-size: 2em;
      margin: 0;
    }

    #gallery-section {
      margin: 30px;
    }

    .gallery-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 6px;
    }

    .gallery-item img {
      width: 100%;
      flex: 1;
      min-height: 0;
      display: block;
      object-fit: contain;
    }

  </style>
</head>

<body>
  <h1 class="page-title">INDEX</h1>
  <div id="gallery-section">
    <div class="gallery-container" id="gallery"></div>
  </div>
  <div id="top-right-section">
    <div id="map-section">
      <h2>MAP</h2>
    </div>
    <div id="about-section" style="margin-top: 10px;">
      <h2>ABOUT</h2>
    </div>
  </div>

  <script>

    const objects = [
      { name:'bucket', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/bucket-280102026-negative.png' },
