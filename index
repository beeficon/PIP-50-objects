const defaultCursor = "https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cursor%2064x64.png";
const clickCursor = "https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cursor%202%2064x64.png";

const gallery = document.getElementById('gallery');

objects.forEach(obj => {
  const item = document.createElement('div');
  item.className = 'gallery-item';

  const img = document.createElement('img');
  const positive = obj.image.replace('-negative','');

  img.src = obj.image;
  img.dataset.src = obj.image;
  img.dataset.pos = positive;
  img.loading = 'lazy';

  img.style.cursor = `url("${defaultCursor}") 32 32, auto`;

  const overlay = document.createElement('div');
  overlay.className = 'overlay';

  overlay.innerHTML = `
  <div class="title">${obj.name}</div>
  <div class="desc">
    ${obj.category}<br>
    ${obj.material}<br>
    ${obj.lat}<br>
    ${obj.lng}<br>
    ${obj.found}<br>
    ${obj.missing}
  </div>
  `;

  item.addEventListener('mouseenter', () => {
    img.style.cursor = `url("${clickCursor}") 32 32, auto`;
  });
  item.addEventListener('mouseleave', () => {
    img.style.cursor = `url("${defaultCursor}") 32 32, auto`;
  });

  item.addEventListener('click', () => {
    const hidden = img.style.opacity === '0';
    img.style.opacity = hidden ? '1' : '0';
    overlay.style.opacity = hidden ? '0' : '1';

  });
  item.appendChild(img);
  item.appendChild(overlay);
  gallery.appendChild(item);

});
