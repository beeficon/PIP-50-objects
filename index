      { name:'traffic cones', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cones-28012026-negative.png' },
      { name:'tshirt', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/tshirt-04022026-negative.png' },
      { name:'toilet', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/toilet-04022026-negative.png' },
      { name:'magic whip', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/magic_whip-04022026-negative.png' },
      { name:'mirror', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/mirror-04022026-negative.png' },
      { name:'cushion', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/cushions-04022026-negative.png' },
      { name:'tyre parts', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/tyre-04022026-negative.png' },
      { name:'sofa', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/sofa-04022026-negative.png' },
      { name:'seat', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/seat-04022026-negative.png' },
      { name:'bin bags', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/bin_bags-04022026-negative.png' },
      { name:'sofa part', image:'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/mattress-04022026-negative.png' },
