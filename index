      top: 30px;
      right: -100px;
      width: 250px;
      background: rgba(255, 255, 255, 0.8);
      padding: 10px;
      border-radius: 8px;
      z-index: 200;
    }

    #top-right-section h2 {
      margin-bottom: -10px;
      font-size: 1.5em;
    }

  </style>
