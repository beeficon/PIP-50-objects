];

// Shuffle a copy of IMAGES and return an index-cycling picker per letter
function makePicker() {
  // Each letter gets its own shuffled queue
  let queue = [...IMAGES].sort(() => Math.random() - 0.5);
  let i = 0;
  return function next() {
    const img = queue[i % queue.length];
    i++;
    // Reshuffle when we've gone through all
    if (i % queue.length === 0) {
      queue = [...IMAGES].sort(() => Math.random() - 0.5);
    }
    return img;
  };
}

function buildWord(containerId, text) {
  const container = document.getElementById(containerId);
  for (const char of text) {
    const wrap = document.createElement('div');
    wrap.className = 'letter-wrap' + (char === ' ' ? ' space' : '');

    if (char !== ' ') {
      const span = document.createElement('span');
      span.className = 'letter-text';
      span.textContent = char;

      const img = document.createElement('img');
      img.className = 'letter-img';
      img.alt = char;

      const pick = makePicker();

      // Set initial image
      img.src = pick();

      // On each hover, swap to the next image
      wrap.addEventListener('mouseenter', () => {
        img.src = pick();
      });

      wrap.appendChild(span);
      wrap.appendChild(img);
    }

    container.appendChild(wrap);
  }
}

buildWord('word-street', 'STREET');
buildWord('word-objects', 'OBJECTS');
