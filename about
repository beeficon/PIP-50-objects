<div id="about-text">
  <h2>This project is about mapping and being conscious of the unconscious parts of our streets. Over the 8 walks I undertook in the 33-day time span, I found 90+ items just a 15-minute walk from my house.</h2>
  <div id="about-text">
  <h2>Some of the stuff was brand new and I took them home with me. Some were taken by others, and some were left on the street for the entire experiment.</h2>
 <div id="about-text">
  <h2>London is overwhelming in its offerings, so much that these little gifts go overlooked. What you need is right in front of you.</h2>
  <div id="image-container"></div>
</div>
<script>
const objects = [
  { name: 'chair', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/chair-16022026.png' },
  { name: 'sofa', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/sofa-28012026.png' },
  { name: 'wheel trimming', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/wheel-18022026.png' },
  { name: 'motherboard', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/motherboard-18022026.png' },
  { name: 'egg carton', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/eggs-18022026.png' },
  { name: 'lamp', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/lamp-18022026.png' },
  { name: 'bowls', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/bowl-02032026.png' },
  { name: 'balloon', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/balloon-12022026.png' },
  { name: 'granny trolley', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/granny_trolley-04022026.png' },
  { name: 'sofa part', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/mattress-04022026.png' },
  { name: 'bin bags', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/bin_bags-04022026.png' },
  { name: 'toilet', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/toilet-04022026.png' },
  { name: 'pot', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/pot-18022026.png' },
  { name: 'pan', image: 'https://raw.githubusercontent.com/beeficon/PIP-50-objects/main/pan-25022026.png' }
];

const container = document.getElementById('image-container');

let currentDraggedImage = null;
let offsetX = 0;
let offsetY = 0;

// Generate random positions for each image
objects.forEach((obj, index) => {
  const img = document.createElement('img');
  img.src = obj.image;
  img.className = 'draggable-image';

  const maxWidth = window.innerWidth - 100;
  const maxHeight = window.innerHeight - 100;

  const randomLeft = Math.random() * maxWidth;
  const randomTop = Math.random() * maxHeight;

  img.style.top = `${randomTop}px`;
  img.style.left = `${randomLeft}px`;
  img.style.position = 'absolute';

  // Mouse down to start dragging
  img.addEventListener('mousedown', (e) => {
    currentDraggedImage = img;
    offsetX = e.clientX - parseFloat(img.style.left);
    offsetY = e.clientY - parseFloat(img.style.top);
    img.style.zIndex = 1000; // bring to front
  });

  container.appendChild(img);
});

// Mouse move moves the current dragged image
document.addEventListener('mousemove', (e) => {
  if (currentDraggedImage) {
    currentDraggedImage.style.left = `${e.clientX - offsetX}px`;
    currentDraggedImage.style.top = `${e.clientY - offsetY}px`;
  }
});

// Mouse up to stop dragging
document.addEventListener('mouseup', () => {
  if (currentDraggedImage) {
    currentDraggedImage.style.zIndex = '';
    currentDraggedImage = null;
  }
});
</script>
